# Copy to .env and fill locally. Never commit real keys.
APP_ENV=development
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
ENABLE_DEBUG_API=true
ENABLE_ADMIN_CONSOLE=true
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=false
SESSION_BACKEND=memory
SESSION_DB_PATH=server/runtime/sessions.sqlite3
SESSION_REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=43200
SESSION_MAX_ITEMS=500
TRACE_MAX_ITEMS=200

# Doubao / Ark OpenAI-compatible API
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=ep-20260514111645-lmgt2
USE_LLM=false
USE_SEMANTIC_LLM=false
LLM_TIMEOUT_SECONDS=45
USE_ARK_EMBEDDING=false
ARK_EMBEDDING_API=text
ARK_EMBEDDING_MODEL=doubao-embedding-text-240515
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_BATCH_SIZE=4

# RAG storage
USE_CHROMA=false
CHROMA_DIR=server/chroma_db
CHROMA_COLLECTION_NAME=products
PRODUCT_DATA_PATH=data/products_ref.json
PRODUCT_IMAGE_DIR=data/product_images
USE_VISUAL_EMBEDDING=false
VISUAL_EMBEDDING_MODEL=
VISUAL_EMBEDDING_INDEX_PATH=server/runtime/product_image_vectors.json
EMBEDDING_CACHE_PATH=server/runtime/embedding_cache.sqlite3
UPLOAD_IMAGE_DIR=server/runtime/uploads/images
UPLOAD_IMAGE_MAX_BYTES=4500000
UPLOAD_IMAGE_TTL_SECONDS=86400
SCENARIO_BUNDLE_PATH=data/scenario_bundles.json
CLARIFICATION_POLICY_PATH=data/clarification_policy.json
PUBLIC_BASE_URL=http://127.0.0.1:8000
