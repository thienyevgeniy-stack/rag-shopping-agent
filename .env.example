# Copy to .env and fill locally. Never commit real keys.
APP_ENV=development
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# Doubao / Ark OpenAI-compatible API
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=ep-20260514111645-lmgt2

# RAG storage
USE_CHROMA=false
CHROMA_DIR=server/chroma_db
PRODUCT_DATA_PATH=data/products_ref.json
